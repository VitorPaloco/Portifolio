---
const { project } = Astro.props;
---

<div class="rounded-2xl overflow-hidden bg-[var(--card)] border border-[var(--border)] hover:border-[var(--primary)] transition duration-300">
  <a href={project.link} target="_blank">
    <div class="aspect-video overflow-hidden">
      <img
        src={project.images[0]}
        alt={project.title}
        class="w-full h-full object-cover"
      />
    </div>

    <div class="p-6 space-y-4">
      <div class="flex justify-between items-start">
        <div>
          <span class="text-[var(--primary)] text-xs uppercase tracking-widest font-semibold">
            {project.category}
          </span>

          <h3 class="text-xl font-bold text-[var(--foreground)] mt-1">
            {project.title}
          </h3>
        </div>
      </div>

      <p class="text-[var(--muted-foreground)] text-sm text-justify">
        {project.description}
      </p>

      <div class="flex flex-wrap gap-2 pt-2">
        {
          project.tech.map((tech: string) => (
            <span class="rounded-md px-3 py-1 text-xs bg-[var(--secondary)] text-[var(--primary)] border border-[var(--border)]">
              {tech}
            </span>
          ))
        }
      </div>
    </div>
  </a>


  
</div>