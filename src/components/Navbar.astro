---
import ThemeIcon from "@components/ThemeIcon.astro";

const navItems = [
  { label: "Home", href: "#home" },
  { label: "Projetos", href: "#projects" },
  { label: "Experiência", href: "#work" },
  { label: "Formação", href: "#education" },
];
---

<header class="sticky top-0 z-50 w-full backdrop-blur border-b border-[var(--border)] bg-[var(--background)]">
  <nav class="max-w-6xl mx-auto flex h-16 items-center justify-between px-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg bg-[var(--primary)] text-[var(--primary-foreground)] flex items-center justify-center font-bold">
        V
      </div>
      <span class="font-bold text-xl text-[var(--foreground)]">Paloco</span>
    </a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center gap-6">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-[var(--foreground)] hover:text-[var(--primary)] transition"
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">

      <ThemeIcon />

      <!-- Mobile Menu -->
      <details class="md:hidden relative">
        <summary class="list-none cursor-pointer px-2 mt-1 text-[var(--foreground)] text-2xl">
          ☰
        </summary>

        <div class="absolute right-0 mt-3 w-52 rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] shadow-lg p-4">
          <div class="flex flex-col gap-4">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class="text-sm font-medium text-[var(--foreground)] hover:text-[var(--primary)] transition"
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </div>
      </details>
      
    </div>
  </nav>
</header>