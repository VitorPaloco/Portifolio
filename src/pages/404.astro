---
import Layout from "@layouts/Layout.astro";
---

<Layout title="404 - Página não encontrada">
  <main class="min-h-screen flex items-center justify-center px-8">
    <div class="max-w-xl text-center border border-[var(--border)] bg-[var(--card)] rounded-[var(--radius)] p-10 shadow-lg">

      <span class="block text-7xl font-extrabold text-[var(--primary)]">
        404
      </span>

      <h1 class="mt-4 text-3xl font-bold text-[var(--foreground)]">
        Página não encontrada
      </h1>

      <p class="mt-4 text-[var(--muted-foreground)] leading-relaxed">
        A página que você tentou acessar não existe ou foi movida.
      </p>

      <a
        href="/"
        class="inline-block mt-8 px-6 py-3 rounded-[var(--radius)] bg-[var(--primary)] text-[var(--primary-foreground)] font-medium hover:opacity-90 transition"
      >
        Voltar ao início
      </a>

    </div>
  </main>
</Layout>